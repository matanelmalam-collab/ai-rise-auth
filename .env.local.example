# =============================================================
# AI Rise Auth Gateway — Environment Variables
# =============================================================
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to version control.
# =============================================================

# --- Clerk Keys (from https://dashboard.clerk.com → API Keys) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLERK_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Clerk Route Config ---
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/callback
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/callback

# --- Base44 Config ---
BASE44_APP_ID=your_base44_app_id_here
NEXT_PUBLIC_BASE44_APP_URL=https://app.base44.com/apps/your-app-id

# --- Bridge Secret (generate with: openssl rand -hex 32) ---
BRIDGE_SECRET=generate_a_64_char_hex_secret_here

# --- Domain (for cookie sharing) ---
NEXT_PUBLIC_COOKIE_DOMAIN=.ai-rise.co.il
